{
  "name": "minimax-api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "npx simple-git-hooks"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^3.0.2",
    "element-plus": "^2.9.9"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.5.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "~5.7.3",
    "vite": "^6.3.4",
    "vue-tsc": "^2.2.10",
    "unocss": "^66.6.7",
    "@iconify-json/ri": "^1.2.5",
    "eslint": "^9.22.0",
    "simple-git-hooks": "^2.12.1",
    "lint-staged": "^15.5.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
