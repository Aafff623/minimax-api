{
  "name": "minimax-api",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "npx simple-git-hooks",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:music": "npx tsx scripts/generate-music.ts",
    "generate:welcome-video": "npx tsx scripts/generate-welcome-video.ts",
    "generate:assets": "npx tsx scripts/generate-ui-assets.ts",
    "generate:placeholders": "npx tsx scripts/generate-svg-placeholders.ts"
  },
  "dependencies": {
    "element-plus": "^2.9.9",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.5.2",
    "@iconify-json/ri": "^1.2.5",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.22.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.1",
    "simple-git-hooks": "^2.12.1",
    "typescript": "~5.7.3",
    "unocss": "^66.6.7",
    "vite": "^6.3.4",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.10"
  },
  "simple-git-hooks": {},
  "lint-staged": {}
}
